ARC_APP_NAME=arc-backend
ARC_ENV=dev
ARC_HOST=0.0.0.0
ARC_PORT=8000

ARC_USE_REDIS_SESSIONS=false
ARC_USE_POSTGRES_MEMORY=false
ARC_ENABLE_TOOL_ROUTER=true
ARC_ENABLE_CRISIS_GUARDRAILS=true

ARC_REDIS_URL=redis://localhost:6379/0
ARC_POSTGRES_DSN=postgresql://arc:arc@localhost:5432/arc
ARC_REDIS_SESSION_KEY_PREFIX=arc:session:
ARC_REDIS_SESSION_TTL_SECONDS=3600

ARC_REQUEST_TIMEOUT_SECONDS=8.0
ARC_MODEL_TIMEOUT_SECONDS=6.0
ARC_MAX_RETRIES=2
ARC_RATE_LIMIT_PER_MINUTE=60
